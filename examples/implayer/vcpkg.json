{
  "name": "implayer",
  "version": "0.1.0",
  "description": "ImPlayer — demo player for the imvideo library",
  "dependencies": [
    "imvideo",
    {
      "name": "ffmpeg",
      "default-features": false,
      "features": ["avcodec", "avformat", "openssl", "swscale", "swresample"]
    },
    {
      "name": "imgui",
      "features": ["glfw-binding", "opengl3-binding", "docking-experimental"]
    },
    "glfw3",
    "tinyfiledialogs"
  ],
  "vcpkg-configuration": {
    "overlay-ports": [ "./overlay" ]
  }
}
