{
  "name": "imvideo",
  "version": "0.1.0",
  "description": "Cross-platform video player library for Dear ImGui applications",
  "homepage": "https://github.com/user/imvideo",
  "dependencies": [
    {
      "name": "ffmpeg",
      "features": ["avcodec", "avformat", "swscale", "swresample"]
    },
    {
      "name": "imgui",
      "features": ["glfw-binding", "opengl3-binding", "docking-experimental"]
    },
    {
      "name": "glfw3"
    },
    {
      "name": "miniaudio"
    }
  ]
}
